# Example environment variables for backend
# Copy this to .env and fill in with your actual values
# NEVER commit the actual .env file!

PORT=5000
MONGODB_URI=mongodb://localhost:27017/erp_system
JWT_SECRET=change_this_to_a_very_secure_random_string_minimum_32_characters
JWT_EXPIRE=7d
NODE_ENV=development

# For production, use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/erp_system?retryWrites=true&w=majority
